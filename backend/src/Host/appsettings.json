{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=eduplatform;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "your-very-secret-key-change-in-production-min-32-chars",
    "Issuer": "EduPlatform",
    "Audience": "EduPlatformUsers",
    "AccessTokenExpirationMinutes": 15
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "FromEmail": "your-email@gmail.com",
    "FromName": "EduPlatform"
  },
  "FrontendUrl": "http://localhost:4200",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "eduplatform-files",
    "UseSSL": false
  },
  "AllowedHosts": "*"
}
